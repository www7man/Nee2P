# Nee2P relay environment — copy to .env and edit
# (loaded by docker-compose; for `npm start` export the vars manually)

# ─── Network ──────────────────────────────────────────────────
# Port the relay listens on
PORT=8787

# Bind address. Use 127.0.0.1 behind a reverse proxy,
# 0.0.0.0 when exposing the container directly.
HOST=127.0.0.1

# ─── Admin dashboard (/admin.html) ────────────────────────────
# Sent as `X-Admin-Key` header by the dashboard. Change this!
ADMIN_KEY=change-me-to-a-long-random-string

# ─── Web Push (optional) ──────────────────────────────────────
# Push notifications are read from ~/.nee2p-vapid.json on first
# boot. Generate keys once with:
#   npx web-push generate-vapid-keys
# and write the JSON like:
#   { "publicKey": "B...", "privateKey": "..." }
# to ~/.nee2p-vapid.json. Leaving the file absent disables push.
